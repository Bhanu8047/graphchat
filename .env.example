# ── Embedding ───────────────────────────────────────────────────
EMBEDDING_PROVIDER=voyage
VOYAGE_API_KEY=your_voyage_api_key_here
# VOYAGE_BASE_URL=https://ai.mongodb.com/v1
VOYAGE_BASE_URL=https://api.voyageai.com/v1
VOYAGE_MODEL=voyage-code-3

# ── LLM ─────────────────────────────────────────────────────────
LLM_PROVIDER=claude
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL=claude-sonnet-4-5-20250929

# Alternatives (uncomment to use)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_EMBED_MODEL=text-embedding-3-small
OPENAI_MODEL=gpt-4o-mini

# LLM_PROVIDER=google
LLM_PROVIDER=google
GEMINI_API_KEY=your_google_api_key_here
GEMINI_MODEL=gemini-3-flash-preview

# LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free

# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2
# OLLAMA_EMBED_MODEL=nomic-embed-text

# ── Databases ───────────────────────────────────────────────────
MONGO_INITDB_ROOT_USERNAME=root
MONGO_INITDB_ROOT_PASSWORD=secretpassword
MONGO_INITDB_DATABASE=graphchat
REDIS_URL=redis://localhost:6379
MONGODB_URI=mongodb://root:secretpassword@localhost:27017/graphchat?authSource=admin

# ── App ─────────────────────────────────────────────────────────
WEB_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001/api
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_SESSION_COOKIE_DOMAIN=.localhost

# ── Security ──────────────────────────────────────────────────────
APP_TRUSTED_HOSTS=localhost
APP_CANONICAL_HOST=localhost
GRAPHCHAT_SERVER=http://localhost:3001
GRAPHCHAT_WS_SERVER=ws://localhost:3001

# ── GitHub OAuth ───────────────────────────────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── JWT Auth ───────────────────────────────────────────────
API_JWT_SECRET=supersecretkey
AUTH_SESSION_SECRET=anothersecretkey
API_JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_DAYS=30

# ── CREDENTIALS KEYS ────────────────────────────────────────────
CREDENTIAL_ENCRYPTION_KEY=32_characters_long_key_here