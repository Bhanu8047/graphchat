{
  "name": "@vectorgraph/web",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "start": "next start"
  },
  "nx": {
    "name": "web",
    "tags": [
      "scope:web",
      "type:app"
    ],
    "targets": {
      "build": {
        "executor": "nx:run-commands",
        "options": {
          "command": "NODE_ENV=production next build --webpack",
          "cwd": "apps/web"
        },
        "outputs": [
          "{projectRoot}/.next",
          "{projectRoot}/.next/!(cache)"
        ]
      }
    }
  }
}
