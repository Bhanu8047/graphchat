{
  "name": "@trchat/web",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "start": "next start"
  },
  "nx": {
    "name": "web",
    "tags": [
      "scope:web",
      "type:app"
    ],
    "targets": {
      "serve": {
        "continuous": true,
        "executor": "nx:run-commands",
        "options": {
          "command": "next dev",
          "cwd": "apps/web"
        }
      },
      "build": {
        "executor": "nx:run-commands",
        "cache": true,
        "options": {
          "command": "NODE_ENV=production next build --webpack",
          "cwd": "apps/web"
        },
        "outputs": [
          "{projectRoot}/.next",
          "{projectRoot}/.next/!(cache)"
        ]
      }
    }
  },
  "dependencies": {
    "@tiptap/extension-typography": "^3.22.5",
    "@tiptap/react": "^3.22.5",
    "@tiptap/starter-kit": "^3.22.5"
  }
}
