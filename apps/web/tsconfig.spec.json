{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./out-tsc/jest",
    "module": "commonjs",
    "moduleResolution": "node",
    "types": ["jest", "node"],
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "noEmit": true,
    "emitDeclarationOnly": false,
    "composite": false,
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "jest.config.ts",
    "jest.config.cts",
    "src/**/*.test.ts",
    "src/**/*.spec.ts",
    "src/**/*.test.tsx",
    "src/**/*.spec.tsx",
    "src/**/*.d.ts"
  ],
  "exclude": [
    "out-tsc",
    "dist",
    ".next",
    "eslint.config.js",
    "eslint.config.cjs",
    "eslint.config.mjs"
  ]
}
