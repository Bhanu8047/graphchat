{
  "name": "@graphchat/gph",
  "version": "0.1.0-beta.4",
  "description": "graphchat CLI (gph) — Repository context graph for AI agents (beta)",
  "bin": {
    "gph": "dist/main.js"
  },
  "main": "dist/main.js",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "copy-wasm": "node ./scripts/copy-wasm.js"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public",
    "tag": "beta"
  },
  "keywords": [
    "graphchat",
    "gph",
    "cli",
    "knowledge-graph",
    "ai-agents",
    "vector-search"
  ],
  "license": "MIT",
  "homepage": "https://github.com/bhanu8047/graphchat#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/bhanu8047/graphchat.git",
    "directory": "apps/cli"
  },
  "nx": {
    "name": "cli",
    "tags": [
      "scope:cli",
      "type:app"
    ],
    "targets": {
      "build": {
        "executor": "nx:run-commands",
        "cache": true,
        "options": {
          "commands": [
            "tsc -b tsconfig.app.json",
            "node ./scripts/copy-wasm.js"
          ],
          "parallel": false,
          "cwd": "apps/cli"
        },
        "outputs": [
          "{projectRoot}/dist"
        ]
      }
    }
  },
  "dependencies": {
    "axios": "^1.13.5",
    "chalk": "^5.6.2",
    "chokidar": "^4.0.3",
    "commander": "^14.0.2",
    "conf": "^15.1.0",
    "ignore": "^7.0.5",
    "inquirer": "^13.4.2",
    "open": "^10.2.0",
    "ora": "^9.4.0",
    "stdin-discarder": "^0.3.2",
    "web-tree-sitter": "^0.20.8",
    "yoctocolors": "^2.1.2"
  },
  "devDependencies": {
    "tree-sitter-wasms": "^0.1.13"
  }
}
