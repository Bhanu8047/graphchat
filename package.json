{
  "name": "vectorgraph",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "start:api": "nx serve api",
    "start:web": "nx serve web",
    "start:app": "cross-env NODE_OPTIONS=--no-deprecation nx serve app",
    "build:api": "nx build api",
    "build:web": "nx build web",
    "test:api": "nx test api",
    "test:web": "nx test web",
    "lint:api": "nx lint api",
    "lint:web": "nx lint web",
    "prepare": "husky",
    "commitlint": "commitlint",
    "format": "prettier --write --ignore-unknown \"apps/api/**/*\" \"apps/web/**/*\" \"libs/**/*\"",
    "format:check": "prettier --check --ignore-unknown \"apps/api/**/*\" \"apps/web/**/*\" \"libs/**/*\"",
    "format:staged": "lint-staged",
    "docker": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:prod": "docker-compose -f docker-compose.prod.yml up -d --build",
    "docker:logs": "docker-compose logs -f",
    "release": "nx release --skip-publish",
    "check": "nx run-many -t lint test build typecheck",
    "clean": "rm -rf dist && rm -rf apps/**/dist && nx reset && rm -rf apps/**/out-tsc && rm -rf apps/**/.next && rm -rf apps/**/tsconfig.lib.tsbuildinfo && rm -rf apps/**/tsconfig.app.tsbuildinfo && rm -rf libs/**/dist && rm -rf libs/**/out-tsc && rm -rf libs/**/.next && rm -rf libs/**/tsconfig.lib.tsbuildinfo && rm -rf libs/**/tsconfig.app.tsbuildinfo"
  },
  "private": true,
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@eslint/js": "^10.0.1",
    "@nestjs/cli": "^11.0.21",
    "@nx/eslint": "^22.7.1",
    "@nx/eslint-plugin": "^22.7.1",
    "@nx/jest": "^22.7.1",
    "@nx/js": "22.7.0",
    "@nx/nest": "^22.7.1",
    "@nx/next": "^22.7.1",
    "@nx/node": "^22.7.1",
    "@nx/react": "^22.7.1",
    "@nx/webpack": "^22.7.1",
    "@swc-node/register": "1.11.1",
    "@swc/core": "1.15.8",
    "@swc/helpers": "0.5.18",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/cookie-parser": "^1.4.10",
    "@types/d3": "^7.4.3",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "eslint": "^10.3.0",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "lint-staged": "^15.5.2",
    "nx": "22.7.1",
    "postcss": "^8.5.13",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.4",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "tslib": "^2.3.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.59.1",
    "webpack": "^5.106.2",
    "webpack-cli": "^7.0.2"
  },
  "lint-staged": {
    "{apps/api,apps/web,libs}/**/*": "prettier --write --ignore-unknown"
  },
  "workspaces": [
    "apps/*",
    "libs/*"
  ],
  "dependencies": {
    "@anthropic-ai/sdk": "^0.92.0",
    "@google/generative-ai": "^0.24.1",
    "@nestjs/common": "^11.1.19",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.19",
    "@nestjs/platform-express": "^11.1.19",
    "@redis/client": "^5.12.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "cookie-parser": "^1.4.7",
    "d3": "^7.9.0",
    "jsonwebtoken": "^9.0.3",
    "mongodb": "^7.2.0",
    "motion": "^12.38.0",
    "next": "^16.2.4",
    "openai": "^6.35.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "redis": "^4.7.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2",
    "uuid": "^14.0.0"
  }
}
