{
  "name": "vectorgraph",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "api:dev": "ts-node --project apps/api/tsconfig.json apps/api/src/main.ts",
    "api:build": "tsc -p apps/api/tsconfig.json",
    "web:dev": "next dev apps/web -p 3000",
    "web:build": "next build apps/web",
    "prepare": "husky",
    "commitlint": "commitlint",
    "format": "prettier --write --ignore-unknown \"apps/api/**/*\" \"apps/web/**/*\" \"libs/**/*\"",
    "format:check": "prettier --check --ignore-unknown \"apps/api/**/*\" \"apps/web/**/*\" \"libs/**/*\"",
    "nx:serve:api": "npm run api:dev",
    "nx:serve:web": "npm run web:dev",
    "docker": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:prod": "docker-compose -f docker-compose.prod.yml up -d --build",
    "docker:logs": "docker-compose logs -f"
  },
  "private": true,
  "devDependencies": {
    "@nx/eslint": "^22.7.1",
    "@nx/eslint-plugin": "^22.7.1",
    "@nx/js": "22.7.0",
    "@nx/nest": "^22.7.1",
    "@nx/next": "^22.7.1",
    "@nx/node": "^22.7.1",
    "@nx/react": "^22.7.1",
    "@nx/webpack": "^22.7.1",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@swc-node/register": "1.11.1",
    "@swc/core": "1.15.8",
    "@swc/helpers": "0.5.18",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/cookie-parser": "^1.4.10",
    "@types/d3": "^7.4.3",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "husky": "^9.1.7",
    "nx": "22.7.1",
    "postcss": "^8.5.13",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.4",
    "ts-node": "^10.9.2",
    "tslib": "^2.3.0",
    "typescript": "~5.9.2"
  },
  "workspaces": [
    "apps/*",
    "libs/*"
  ],
  "dependencies": {
    "@anthropic-ai/sdk": "^0.92.0",
    "@google/generative-ai": "^0.24.1",
    "@nestjs/common": "^11.1.19",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.19",
    "@nestjs/platform-express": "^11.1.19",
    "@redis/client": "^5.12.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "cookie-parser": "^1.4.7",
    "d3": "^7.9.0",
    "jsonwebtoken": "^9.0.3",
    "mongodb": "^7.2.0",
    "motion": "^12.38.0",
    "next": "^16.2.4",
    "openai": "^6.35.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "redis": "^4.7.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2",
    "uuid": "^14.0.0"
  }
}
